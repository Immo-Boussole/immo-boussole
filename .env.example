# ── Immo-Boussole Environment Variables ──────────────────────────────────────
# Copier ce fichier en .env et renseigner les valeurs

# Base de données (chemin absolu pour Docker, relatif pour dev local)
# Dev local (défaut) : sqlite:///./immo_boussole.db
# Docker            : sqlite:////app/data/immo_boussole.db
DATABASE_URL=sqlite:///./immo_boussole.db

# URL du service Browserless (headless Chrome via CDP)
# Dev local  : ws://localhost:3000
# Docker     : ws://browserless:3000
BROWSERLESS_URL=ws://localhost:3000

# Token d'authentification Browserless (optionnel)
# Si défini, toutes les connexions CDP doivent inclure ce token
BROWSERLESS_TOKEN=

# Intervalle de scraping automatique (en heures)
SCRAPING_INTERVAL_HOURS=12

# Clé API ScrapingBee (optionnelle - alternative de secours)
# SCRAPINGBEE_API_KEY=your_key_here

# Mode debug (false en production)
DEBUG=false

# Authentification
APP_PASSWORD=votre_mot_de_passe
SECRET_KEY=une_cle_secrete_tres_longue_et_aleatoire
