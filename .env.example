# ── Immo-Boussole Environment Variables ──────────────────────────────────────
# Copier ce fichier en .env et renseigner les valeurs

# Base de données (chemin absolu pour Docker, relatif pour dev local)
# Dev local (défaut) : sqlite:///./immo_boussole.db
# Docker            : sqlite:////app/data/immo_boussole.db
DATABASE_URL=sqlite:///./immo_boussole.db

# URL du service PinchTab (headless browser)
# Dev local  : http://127.0.0.1:9867
# Docker     : http://host.docker.internal:9867
PINCHTAB_URL=http://127.0.0.1:9867

# Intervalle de scraping automatique (en heures)
SCRAPING_INTERVAL_HOURS=12

# Clé API ScrapingBee (optionnelle - alternative à PinchTab)
# SCRAPINGBEE_API_KEY=your_key_here

# Mode debug (false en production)
DEBUG=false

# ── Résolution de Captcha (FlareSolverr) ───────────────────────────────────
# Activer le solver : 2captcha (nécessite une clé API) ou none
CAPTCHA_SOLVER=none
# Votre clé API 2Captcha (si CAPTCHA_SOLVER=2captcha)
TWO_CAPTCHA_API_KEY=
