# ── Immo-Boussole Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values

# Database (absolute path for Docker, relative for local development)
# Local development (default): sqlite:///./immo_boussole.db
# Docker: sqlite:////app/data/immo_boussole.db
DATABASE_URL=sqlite:///./immo_boussole.db

# Browserless service URL (headless Chrome via CDP)
# Local development: ws://localhost:3000
# Docker: ws://browserless:3000
BROWSERLESS_URL=ws://localhost:3000

# Browserless authentication token (optional)
# If defined, all CDP connections must include this token
BROWSERLESS_TOKEN=

# Automatic scraping interval (in hours)
SCRAPING_INTERVAL_HOURS=12

# ScrapingBee API key (optional - fallback alternative)

# Debug mode (false in production)
DEBUG=false

# Authentication
APP_PASSWORD=your_password
SECRET_KEY=a_very_long_and_random_secret_key
